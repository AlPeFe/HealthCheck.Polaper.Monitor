{
  "Monitor": {
    "InstanceId": "CLIENTE-GAM-01",
    "Alerts": {
      "DefaultThrottle": "00:30:00",
      "Email": {
        "Enabled": false,
        "From": "monitor@example.com",
        "To": [ "operations@example.com" ],
        "SmtpHost": "smtp.example.com",
        "SmtpPort": 587,
        "Security": "StartTls",
        "Username": "monitor@example.com",
        "Password": ""
      }
    },
    "Dashboard": {
      "Enabled": true,
      "Urls": [ "http://localhost:5080" ]
    },
    "HealthChecks": {
      "Enabled": true,
      "Publisher": {
        "Delay": "00:00:10",
        "Period": "00:05:00",
        "Timeout": "00:00:30",
        "RequiredTag": "monitor"
      },
      "Endpoints": {
        "All": "/healthz",
        "Live": "/healthz/live",
        "Ready": "/healthz/ready"
      }
    },
    "Persistence": {
      "Provider": "Sqlite",
      "ConnectionString": "Data Source=gam-monitor-state.db",
      "EnableHistory": false,
      "HistoryRetentionDays": 7
    },
    "Plugins": {
      "Process": { "PluginId": "process", "Enabled": true, "DefaultInterval": "00:00:50", "Items": [] },
      "HttpEndpoint": { "PluginId": "http-endpoint", "Enabled": true, "DefaultInterval": "00:00:50", "Items": [] },
      "DiskSpace": { "PluginId": "disk-space", "Enabled": true, "DefaultInterval": "00:05:00", "Items": [] },
      "SqlServer": { "PluginId": "sql-server", "Enabled": true, "DefaultInterval": "00:01:00", "Items": [] },
      "Certificate": { "PluginId": "certificate", "Enabled": true, "DefaultInterval": "12:00:00", "Items": [] }
    }
  },
  "Serilog": {
    "MinimumLevel": { "Default": "Information", "Override": { "Microsoft": "Warning", "System": "Warning" } },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "File", "Args": { "path": "Logs/gam-monitor-.log", "rollingInterval": "Day", "retainedFileCountLimit": 14 } }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": { "Application": "GamMonitorService" }
  }
}
